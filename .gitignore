# Dependencies
node_modules/

# Build output
dist/
dist-types/
build/

# TypeScript incremental build info
*.tsbuildinfo

# Env / secrets (Supabase keys, etc.)
.env
.env.*
!.env.example

# Generated puzzle banks / local artifacts
*.local.json

# Transient session scratch at repo root (handoffs, findings, ad-hoc verify
# scripts). Real docs live in docs/; these are throwaway working notes that kept
# landing at root. Anchored to root so docs/ is unaffected.
/HANDOFF-*.md
/FINDINGS-*.md
/verify-*.mjs

# Claude memory — junctioned here from ~/.claude/projects/.../memory so it's
# locally monitorable, but it holds infra/run notes that must not ship to this
# PUBLIC repo. Keep it out of git. (.claude/settings.local.json stays untracked too.)
.claude/memory/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
__pycache__/
